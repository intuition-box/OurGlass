# Serves two static apps on one origin:
#   /            -> the Fumadocs website (landing + docs + blog), Next static export
#   /safe-app/*  -> the Vite Safe App SPA
# Safe loads the domain root in its iframe; the website redirects the iframe to
# /safe-app, where the apps-SDK handshake runs. manifest.json + logo.svg live at
# the root so Safe can fetch them cross-origin.
:80 {
	encode gzip
	root * /srv

	# CORS so Safe (app.safe.global) can fetch manifest.json cross-origin, and
	# drop X-Frame-Options so the app can be framed inside the Safe web app.
	header {
		Access-Control-Allow-Origin "*"
		Access-Control-Allow-Methods "GET, OPTIONS"
		Access-Control-Allow-Headers "*"
		-X-Frame-Options
	}

	# Answer CORS preflight without hitting a route.
	@options method OPTIONS
	respond @options 204

	# Content-addressed bundles (hashed filenames) never change — cache hard.
	@immutable path /safe-app/assets/* /_next/*
	header @immutable Cache-Control "public, max-age=31536000, immutable"

	# Everything else must revalidate so a new deploy is picked up immediately.
	@revalidate not path /safe-app/assets/* /_next/*
	header @revalidate Cache-Control "no-cache"

	# The Vite Safe App SPA. handle_path strips the /safe-app prefix; the app was
	# built with base=/safe-app/ so its asset URLs resolve correctly. Unknown
	# sub-paths fall back to the SPA's index.html for client-side routing.
	handle_path /safe-app/* {
		root * /srv/safe-app
		try_files {path} /index.html
		file_server
	}
	@safeapproot path /safe-app
	redir @safeapproot /safe-app/ 308

	# The Fumadocs static export owns the root and everything else. Clean URLs map
	# to the exported .html files (e.g. /docs/security -> /docs/security.html).
	handle {
		try_files {path} {path}.html {path}/index.html
		file_server
	}
}
