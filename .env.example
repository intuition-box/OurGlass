VITE_PINATA_JWT=your_pinata_jwt_here

# Base URL of the external, independently-hosted delegation verifier (separate
# repo, pinned to IPFS). Used to deep-link out from a subscription's detail view.
# Interim (no ENS yet): the verifier's current IPFS CID URL — update on each re-pin.
# VITE_VERIFIER_URL=https://bafybeiaqtihw7t77vgx6s2q53uolr2v75ojvumhzae4dqa366ht2uyp2cm.ipfs.dweb.link/
# Once ENS is registered, switch to the stable name (set once, never changes):
# VITE_VERIFIER_URL=https://verify.ourglass.eth.limo/
